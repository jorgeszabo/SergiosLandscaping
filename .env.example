# ─────────────────────────────────────────────────────────────────────────────
# Sergio's Irrigation — environment variables
#
# The app runs fully WITHOUT any of these (local-first / offline mode, data in
# the browser). Set them only when you want a shared server database + real
# multi-user accounts. See README "Turning on the server backend".
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string. On Vercel, provisioning a Postgres/Neon database
# sets this for you automatically. Locally, paste your connection string here.
# When absent, the app uses the offline (browser) store.
DATABASE_URL=

# Secret used to sign session cookies (server auth). Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=
