# ─────────────────────────────────────────────────────────────────────────────
# Sergio's Landscaping — irrigation app · environment variables
#
# The app runs fully WITHOUT any of these (local-first / offline mode, data in
# the browser). Set them to enable a shared server database + real multi-user
# accounts. Copy this file to `.env` and fill in real values.
#
#   ⚠  NEVER commit `.env` — it is git-ignored. This example holds no secrets.
#
# Hosting-agnostic: works on Vercel + Neon, or fully self-hosted (Docker /
# your own server + Postgres). See docs/SELF_HOSTING.md.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string (server backend). Any Postgres works — Neon,
# a self-hosted server, RDS, etc. When absent, the app uses the offline store.
#   • Vercel + Neon: set automatically by the integration.
#   • Self-hosted with docker-compose: leave this blank here; compose builds it
#     from POSTGRES_PASSWORD below.
#   • Self-hosted, app only: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Secret used to sign session cookies (server auth). REQUIRED with a database.
# Generate a strong value:   openssl rand -base64 32
AUTH_SECRET=

# Google Maps browser key (address autocomplete, "use my location", site map).
# Optional — the map features hide themselves when it's blank. This is a PUBLIC,
# referrer-restricted key (it ships to the browser), not a server secret.
# NOTE: NEXT_PUBLIC_* values are baked in at BUILD time.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── docker-compose only ──────────────────────────────────────────────────────
# Password for the bundled Postgres container (compose builds DATABASE_URL from
# it). Choose a strong value.
POSTGRES_PASSWORD=
